{
  "name": "@chatool/api",
  "version": "0.1.0",
  "description": "Framework-agnostic, fully injectable HTTP client and typed services for Chatool apps (no process.env, no server directives).",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "llms.txt"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/gen-llms.mjs ."
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
