{
  "name": "@karnameh/icons",
  "version": "0.0.0",
  "description": "Tree-shakeable React SVG icon components for Karnameh apps, generated from raw SVGs with SVGR.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "svgr --config-file svgr.config.mjs --out-dir src -- svg",
    "prebuild": "pnpm generate",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
