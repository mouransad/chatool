{
  "name": "@chatool/icons",
  "version": "0.2.0",
  "description": "Tree-shakeable React SVG icon components for Chatool apps, generated from raw SVGs with SVGR.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "llms.txt"
  ],
  "exports": {
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "svgr --config-file svgr.config.mjs --out-dir src -- svg",
    "prebuild": "pnpm generate",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/gen-llms.mjs ."
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
