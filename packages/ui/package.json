{
  "name": "@chatool/ui",
  "version": "0.3.0",
  "description": "Material Design 3 React UI components for Chatool apps. Requires @chatool/core for design tokens.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "llms.txt"
  ],
  "exports": {
    "./button": {
      "import": {
        "types": "./dist/button.d.mts",
        "default": "./dist/button.mjs"
      },
      "require": {
        "types": "./dist/button.d.cts",
        "default": "./dist/button.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/gen-llms.mjs ."
  },
  "dependencies": {
    "@chatool/utils": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "radix-ui": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
