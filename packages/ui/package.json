{
  "name": "@chatool/ui",
  "version": "0.1.0",
  "description": "Shadcn-based React UI components and icons for Chatool apps. Requires @chatool/styles for design tokens.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./button": {
      "import": {
        "types": "./dist/button.d.mts",
        "default": "./dist/button.mjs"
      },
      "require": {
        "types": "./dist/button.d.cts",
        "default": "./dist/button.cjs"
      }
    },
    "./dropdown-menu": {
      "import": {
        "types": "./dist/dropdown-menu.d.mts",
        "default": "./dist/dropdown-menu.mjs"
      },
      "require": {
        "types": "./dist/dropdown-menu.d.cts",
        "default": "./dist/dropdown-menu.cjs"
      }
    },
    "./bottom-sheet": {
      "import": {
        "types": "./dist/bottom-sheet.d.mts",
        "default": "./dist/bottom-sheet.mjs"
      },
      "require": {
        "types": "./dist/bottom-sheet.d.cts",
        "default": "./dist/bottom-sheet.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chatool/icons": "workspace:^",
    "@chatool/utils": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "radix-ui": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
